datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Transacao {
  id         Int            @id @default(autoincrement())
  descricao  String   
  criadoEm   DateTime       @default(now())
  tipo       Tipo           @default(DESPESA)
  valor      Decimal        @db.Decimal(15,2)
  status     Status         @default(PENDENTE)
}

enum Tipo{
  DESPESA
  RECEITA
}

enum Status{
  PENDENTE
  CONSOLIDADO
  CANCELADO
}